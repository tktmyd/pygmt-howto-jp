 -0.5, 4.5], \n    spacing = '0.02/0.02',\n    tension = 0.5 # 無指定は0\n)\n\ngriddata_x = pygmt.xyz2grd(\n    x       = mesh[0].ravel(), \n    y       = mesh[1].ravel(), \n    z       = data.ravel(), \n    region  = [-0.5, 4.5, -0.5, 4.5], \n    spacing = '1/1',\n    registration = 'p'\n)\n\n\npygmt.makecpt(\n    cmap = 'viridis', \n    series = [0, 1, 0.1], \n    continuous = True\n)\n\nfig.grdimage(\n    grid = griddata_x, \n    projection = 'X10c/10c',\n    frame = ['WSen+tGMT xyz2grd', 'xaf', 'yaf'], \n)\n\nfig.plot(\n    x = mesh[0].ravel(), \n    y = mesh[1].ravel(), \n    style = 'c0.2c', \n    fill  = 'black', \n)\n\n# 右にずれる\nfig.shift_origin( xshift = 11 )\n\nfig.grdimage(\n    grid = griddata_s, \n    projection = 'X10c/10c',\n    frame = ['WSen+tGMT surface', 'xaf', 'yaf']    \n)\n\nfig.grdcontour( \n    grid = griddata_s, \n    pen = 'default,black', \n    annotation = '-'\n)\n\nfig.plot(\n    x = mesh[0].ravel(), \n    y = mesh[1].ravel(), \n    style = 'c0.2c', \n    fill  = 'black', \n)\n\nfig.colorbar(\n    position = '+e'    \n)\n\nfig.show()","visibility":"show","key":"VlFcSdAWaY"},{"type":"outputs","id":"OOhzkJK8f-umElK3z1oda","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{"image/png":{"width":500}},"data":{"image/png":{"content_type":"image/png","hash":"4a828d18b054e1ef412cd3e1594dedb6","path":"/pygmt-howto-jp/build/4a828d18b054e1ef412cd3e1594dedb6.png"},"text/plain":{"content":"<IPython.core.display.Image object>","content_type":"text/plain"}}},"key":"ngXmdAOBgC"}],"visibility":"show","key":"AIJR9zVFo9"}],"visibility":"show","key":"VXCE26qete"},{"type":"block","kind":"notebook-content","data":{"editable":true,"slideshow":{"slide_type":""},"tags":[]},"children":[{"type":"admonition","kind":"note","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Note","key":"N6PcCdYbBX"}],"key":"EGQ8w7UeTF"},{"type":"paragraph","position":{"start":{"line":2,"column":1},"end":{"line":2,"col