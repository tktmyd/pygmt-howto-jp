0c',\n    frame = ['WSen+ttension = 1.0', 'xaf', 'yaf']    \n)\n\nfig.grdcontour( \n    grid = griddata_s2, \n    pen = 'default,black', \n    annotation = '-'\n)\n\nfig.plot(\n    x = mesh[0].ravel(), \n    y = mesh[1].ravel(), \n    style = 'c0.2c', \n    fill  = 'black', \n)\n\nfig.show()","visibility":"show","key":"jIw5I4xDAc"},{"type":"outputs","id":"GMJGY7UqqwNOy07Yqkoa2","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{"image/png":{"width":500}},"data":{"image/png":{"content_type":"image/png","hash":"601d876ffb4f14a0f91dd1313535f053","path":"/pygmt-howto-jp/build/601d876ffb4f14a0f91dd1313535f053.png"},"text/plain":{"content":"<IPython.core.display.Image object>","content_type":"text/plain"}}},"key":"FtL1Yx6WEN"}],"visibility":"show","key":"m98wMO8N1G"}],"visibility":"show","key":"U8eNrm8EXe"}],"key":"PrMGfTcylx"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"地図上への情報描画","url":"/inf-on-map","group":"基本編"},"next":{"title":"時系列データの可視化","url":"/timeseries","group":"基本編"}}},"domain":"http://localhost:3008"}