たPython上の科学技術計算でよく使われるライブラリのデータ型と互換性があるため，研究成果の可視化ツールとしてとても使いやすいと思います．","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"key":"QXjtlZtmdS"}],"key":"oNScHZOyRy"},{"type":"paragraph","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"children":[{"type":"text","value":"Python上の可視化というと，通常のグラフでは","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"tGqjmtWKLx"},{"type":"link","url":"https://matplotlib.org","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"children":[{"type":"text","value":"matplotlib","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"S4QorOItDn"}],"urlSource":"https://matplotlib.org","key":"bCg8Fxy5VI"},{"type":"text","value":"が，地図では","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"b6FE6DK8Ba"},{"type":"link","url":"https://scitools.org.uk/cartopy","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"children":[{"type":"text","value":"cartopy","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"dqgtrKMNgu"}],"urlSource":"https://scitools.org.uk/cartopy","key":"fG6C0UkQOA"},{"type":"text","value":"が広く使われているようです．PyGMTとどちらを使うかは好みの問題だと思いますが，筆者の意見ではPyGMTのほうが美麗なグラフを生成しやすいと思います．また，GMTの地図投影やグリッドデータ（2次元等間隔のメッシュに対して値が割り当てられたデータ）を扱う機能の豊富さは，大変魅力的です．一方，可視化のための処理速度はやや遅めのようです．特に地震学分野ではこれまでGMTが広く使われていたという経緯もあるため，これまでと同じようなやり方で可視化ができるという継続性に魅力を感じる人もいるかもしれません．","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"VgSioN50QW"}],"key":"S1yYvXV7P7"},{"type":"heading","depth":2,"position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"children":[{"type":"text","value":"このページの目指すもの・目指さないもの","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"d5fTKq7FvH"}],"identifier":"id","label":"このページの目指すもの・目指さないもの","html_id":"id","implicit":true,"key":"MJCytaNX25"},{"type":"paragraph","position":{"start":{"line":2